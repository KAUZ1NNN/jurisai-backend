PORT=3001

# ─── Z-API (WhatsApp) ─────────────────────────────────────────────────────────
# Painel Z-API → sua instância → aba "Credenciais"
ZAPI_INSTANCE_ID=     # ex: 3A123BC4DE567FG
ZAPI_TOKEN=           # ex: F1A2B3C4D5E6F7G8H9
ZAPI_SECURITY_TOKEN=  # Security Token gerado no painel

# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=    # sk-ant-...

# ─── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=         # Injetado automaticamente pelo Railway

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria
NODE_ENV=development
